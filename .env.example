# Telegram — Main Bot
TELEGRAM_BOT_TOKEN=           # токен от @BotFather
TELEGRAM_CHANNEL_ID=          # @channel_username или числовой ID
TELEGRAM_ADMIN_CHAT_ID=       # ваш личный chat_id

# Telegram — Commentator Bot (опционально)
COMMENTATOR_BOT_TOKEN=        # токен второго бота (оставь пустым чтобы отключить)

# AI (Groq — бесплатно на console.groq.com)
GROQ_API_KEY=

# Supabase
SUPABASE_URL=                 # https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=    # service role key (не anon key)
SUPABASE_ACCESS_TOKEN=        # personal access token (для CLI, опционально)

# Настройки агента
MAX_RETRY_ATTEMPTS=3
MIN_ENGAGEMENT_LIKES=50
DRY_RUN=false                 # true = не публиковать, только логировать

# Uniqueness check
UNIQUENESS_RECENT_POSTS=10    # сколько последних постов сравнивать

# Image generation (Pollinations.ai — бесплатно, без API-ключа)
IMAGES_ENABLED=true
POLLINATIONS_TIMEOUT_S=30

# Reddit OAuth2 (создать app на https://www.reddit.com/prefs/apps → type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=ai_news_bot   # твой reddit username для User-Agent
REDDIT_MIN_SCORE=20

# Dev.to scraper
DEVTO_MIN_REACTIONS=10

# Cross-source merger
MERGE_SIMILARITY_THRESHOLD=0.6

# Commentator Agent
COMMENTATOR_ENABLED=true
COMMENTATOR_REACT_PROBABILITY=0.7
COMMENTATOR_COMMENT_PROBABILITY=0.7
COMMENTATOR_MIN_DELAY_S=60
COMMENTATOR_MAX_DELAY_S=900
